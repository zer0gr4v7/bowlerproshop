# GEMINI_API_KEY: Optional. If unset, the selector uses deterministic launch-safe fallback recommendations.
GEMINI_API_KEY=""

# APP_URL: Production site URL for self-referential links and future callbacks.
APP_URL="https://bowlerproshop.com"

# VITE_GTM_ID / VITE_GA4_ID: Production analytics IDs (set as build env vars in Cloudflare Pages).
# GA4 property: BowlerProShop.com -> G-NKCCX535CK
# GTM container: GTM-MLHP4RF5 (ION Search account 6357737911)
VITE_GTM_ID="GTM-MLHP4RF5"
VITE_GA4_ID="G-NKCCX535CK"

# VITE_GSC_VERIFICATION: Optional Google Search Console verification token.
# Submit https://bowlerproshop.com/sitemap.xml after the property is verified.
VITE_GSC_VERIFICATION=""

# VITE_CLARITY_ID: Microsoft Clarity project ID. Free heatmaps + session replay.
# Create at https://clarity.microsoft.com/ -> New Project -> copy ID.
VITE_CLARITY_ID=""

# PORT: Hostinger usually injects this for Node.js apps. Keep 3000 for local fallback.
PORT="3000"
